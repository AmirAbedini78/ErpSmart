{
  "name": "ERPSMART Builder Publish Safety Contract",
  "purpose": "Define future publish safety requirements while keeping actual publish forbidden in the current MVP.",
  "safe_for_agent": false,
  "agent_may_plan_publish": true,
  "agent_may_execute_publish": false,
  "future_publish_phases": [
    "validate",
    "publish readiness analyzer",
    "deep conflict analyzer",
    "diagnostic plan artifact",
    "publish dry-run file generator",
    "dry-run review checklist",
    "publish candidate snapshot",
    "human approval gate planning",
    "approval request persistence",
    "approved candidate preflight",
    "publish execution record lock MVP",
    "staged file validation MVP",
    "runtime write plan artifact MVP",
    "runtime write phase planning",
    "publish execution architecture planning",
    "rollback manifest planning",
    "locking and staging planning",
    "dependency impact analysis",
    "dry-run file plan",
    "DB migration plan",
    "permission/menu/route plan",
    "backup/snapshot",
    "publish transaction or staged publish",
    "post-publish smoke",
    "rollback point"
  ],
  "required_preflight_checks": [
    "definition schema valid",
    "publish readiness report generated with writes_performed 0",
    "diagnostic artifact generated under storage/app/builder-publish-readiness only",
    "publish dry-run generated under storage/app/builder-publish-dry-runs only",
    "dry-run review checklist inspected without approval persistence",
    "candidate snapshot created under storage/app/builder-publish-candidates only",
    "human approval gate reviewed; approval request persistence exists but does not publish",
    "approval request persisted without publish execution",
    "approved candidate preflight confirms checksum and candidate snapshot freshness without publish",
    "publish execution record creates control-plane record, lock, preflight report, staging root, rollback manifest draft, and audit events without runtime writes",
    "staged file validation checks storage-only artifacts, path safety, checksums, classifications, and rollback manifest JSON without runtime writes",
    "runtime write plan artifact maps staged files to future runtime paths, applies the allowlist, plans backups, and writes only under storage/app/builder-runtime-write-plans",
    "runtime write phase planning defines allowlists, backups, locks, and rollback manifest updates while actual runtime writes remain forbidden",
    "future publish execution architecture requires explicit human command and final confirmation",
    "future rollback manifest must be created before runtime writes",
    "future publish lock and staging plan must exist before runtime writes",
    "capability support status valid",
    "unsupported features acknowledged",
    "file conflicts checked",
    "route conflicts checked",
    "menu conflicts checked",
    "permission conflicts checked",
    "table and migration conflicts checked",
    "dependency graph built",
    "generated verifier passes",
    "preview output confirms zero runtime writes before publish"
  ],
  "required_snapshots": [
    "definition version",
    "publish manifest",
    "generated file checksum manifest",
    "migration plan",
    "rollback manifest",
    "database backup or table snapshot when destructive or schema-changing work is planned",
    "RAG manifest update plan"
  ],
  "forbidden_current_operations": [
    "publish generated modules",
    "write runtime module files",
    "run generated migrations",
    "register runtime routes",
    "rebuild runtime menus as publish",
    "delete runtime files",
    "drop tables or data",
    "execute rollback"
  ],
  "current_read_only_preflight": {
    "name": "BuilderPublishReadinessAnalyzer",
    "implemented": true,
    "writes_performed": 0,
    "diagnostic_artifact_scope": "storage/app/builder-publish-readiness",
    "runtime_module_effect": "none",
    "publish_executed": false,
    "actual_publish_still_forbidden": true
  },
  "current_review_checklist": {
    "implemented": true,
    "approval_persistence": false,
    "future_approval_gate_implemented": false,
    "actual_publish_still_forbidden": true
  },
