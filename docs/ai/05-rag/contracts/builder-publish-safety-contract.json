  "preview_vs_publish_difference": {
    "preview": "Writes disposable artifacts under storage/app/module-builder-preview and records preview metadata. It does not change the running application.",
    "publish": "Future operation that writes runtime module files, may run migrations, registers routes/menus/permissions, updates caches, and requires backup plus rollback."
  },
  "rollback_requirements": [
    "rollback manifest created before runtime writes",
    "file restore plan",
    "migration rollback or forward-fix plan",
    "data retention decision",
    "cache/menu/route/search rebuild plan",
    "post-rollback smoke",
    "audit log"
  ],
  "agent_notes": [
    "AI Builder Agent may explain or draft a publish plan.",
    "AI Builder Agent must not execute publish, migrations, runtime writes, or rollback.",
    "Publish implementation needs a separate safety-critical task."
  ]
}
