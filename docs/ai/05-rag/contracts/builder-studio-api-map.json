{
  "name": "ERPSMART Builder Studio API Map",
  "base_path": "/api",
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/builder/definitions",
      "purpose": "List Builder definitions for Builder Studio.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "notes": "Read-only list endpoint."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions",
      "purpose": "Create a draft Builder definition.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition"],
      "notes": "Creates version 1, extracts module/entity/resource names, and stores definition_json."
    },
    {
      "method": "GET",
      "path": "/api/builder/definitions/{id}",
      "purpose": "Read one Builder definition with versions and preview runs.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "notes": "Read-only detail endpoint."
    },
    {
      "method": "PUT",
      "path": "/api/builder/definitions/{id}",
      "purpose": "Update draft Builder definition JSON and create a new version snapshot.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition"],
      "notes": "Does not publish or write runtime module files. Resets status to draft when definition_json changes."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/validate",
      "purpose": "Validate definition structure and capability warnings.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition", "validation_report", "report"],
      "notes": "Returns definition and validation report. The report alias is retained for backward compatibility."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/preview",
      "purpose": "Render a sandbox preview under storage/app/module-builder-preview.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition", "preview_run", "validation_report", "output_text"],
      "safety_checks": [
        "validates first",
        "preview path under storage/app/module-builder-preview",
        "output must report Real runtime writes performed: 0",
        "does not publish",
        "does not run migrations",
        "does not write real modules"
      ],
      "notes": "Validates first and does not publish, run migrations, or write real modules."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/archive",
      "purpose": "Archive an unpublished Builder definition.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "uninstall_related": false,
      "destructive_runtime_related": false,
      "response_shape": ["definition", "message"],
      "notes": "Control-plane-only status change. Does not delete runtime modules, files, migrations, tables, or preview artifacts."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/restore",
      "purpose": "Restore an archived Builder definition to draft.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "uninstall_related": false,
      "destructive_runtime_related": false,
      "response_shape": ["definition", "message"],
      "notes": "Control-plane-only status change. Does not change runtime modules, files, migrations, or tables."
    },
    {
      "method": "DELETE",
      "path": "/api/builder/definitions/{id}",
      "purpose": "Delete unpublished Builder draft/control-plane records.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "uninstall_related": false,
      "destructive_runtime_related": false,
      "response_shape": ["message"],
      "notes": "Deletes Builder definition/version/preview-run records only. Does not delete runtime modules, generated files, database tables, migrations, media, business data, or preview artifact directories."
    }
  ]
}
