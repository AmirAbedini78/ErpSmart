{
  "name": "ERPSMART Builder Studio API Map",
  "base_path": "/api",
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/builder/definitions",
      "purpose": "List Builder definitions for Builder Studio.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "notes": "Read-only list endpoint."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions",
      "purpose": "Create a draft Builder definition.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition"],
      "notes": "Creates version 1, extracts module/entity/resource names, and stores definition_json."
    },
    {
      "method": "GET",
      "path": "/api/builder/definitions/{id}",
      "purpose": "Read one Builder definition with versions and preview runs.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "notes": "Read-only detail endpoint."
    },
    {
      "method": "PUT",
      "path": "/api/builder/definitions/{id}",
      "purpose": "Update draft Builder definition JSON and create a new version snapshot.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition"],
      "notes": "Does not publish or write runtime module files. Resets status to draft when definition_json changes."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/validate",
      "purpose": "Validate definition structure and capability warnings.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition", "validation_report", "report"],
      "notes": "Returns definition and validation report. The report alias is retained for backward compatibility."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/preview",
      "purpose": "Render a sandbox preview under storage/app/module-builder-preview.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "response_shape": ["definition", "preview_run", "validation_report", "output_text"],
      "safety_checks": [
        "validates first",
        "preview path under storage/app/module-builder-preview",
        "output must report Real runtime writes performed: 0",
        "does not publish",
        "does not run migrations",
        "does not write real modules"
      ],
      "notes": "Validates first and does not publish, run migrations, or write real modules."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/publish-readiness",
      "purpose": "Analyze publish readiness and dependency impact without publishing.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "writes_performed": 0,
      "response_shape": [
        "safe",
        "status",
        "writes_performed",
        "runtime_module_effect",
        "publish_executed",
        "file_plan",
        "database_plan",
        "capability_impact",
        "conflicts",
        "blockers",
        "warnings",
        "rollback_requirements"
      ],
      "notes": "Analysis only. Does not write runtime files, create modules, run migrations, create preview runs, create versions, or publish."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/publish-dry-run",
      "purpose": "Generate sandboxed publish dry-run files under storage for review.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "runtime_writes_performed": 0,
      "response_shape": [
        "dry_run_root",
        "dry_run_artifacts_written",
        "runtime_writes_performed",
        "publish_executed",
        "runtime_module_effect",
        "files",
        "warnings",
        "blockers",
        "safety"
      ],
      "notes": "Dry-run only. Writes sandbox artifacts under storage/app/builder-publish-dry-runs and does not write runtime modules, migrations, routes, public build assets, preview runs, versions, or publish."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/publish-candidate-snapshot",
      "purpose": "Create a control-plane-only publish candidate snapshot under storage.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "approval_persistence": false,
      "runtime_writes_performed": 0,
      "response_shape": [
        "candidate_id",
        "candidate_root",
        "candidate_snapshot_path",
        "candidate_status",
        "candidate_checklist",
        "forbidden_actions",
        "next_allowed_actions",
        "safety"
      ],
      "notes": "Snapshot only. Writes derived JSON under storage/app/builder-publish-candidates and does not approve publish, publish, copy artifacts into runtime paths, run migrations, create preview runs, create versions, or write runtime modules."
    },
    {
      "method": "GET",
      "path": "/api/builder/definitions/{id}/publish-approval-requests",
      "purpose": "List approval requests for a Builder definition.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "approval_does_not_publish": true,
      "notes": "Read-only control-plane approval request list."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/publish-approval-requests",
      "purpose": "Request approval for a fresh candidate snapshot.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": false,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "approval_does_not_publish": true,
      "runtime_writes_performed": 0,
      "notes": "Creates approval request and audit event. Does not publish."
    },
    {
      "method": "POST",
      "path": "/api/builder/publish-approval-requests/{id}/approve",
      "purpose": "Approve candidate snapshot review state.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": false,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "approval_does_not_publish": true,
      "runtime_writes_performed": 0,
      "notes": "Approval does not publish and may invalidate if checksum changed."
    },
    {
      "method": "POST",
      "path": "/api/builder/publish-approval-requests/{id}/reject",
      "purpose": "Reject candidate snapshot review state.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": false,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "approval_does_not_publish": true,
      "runtime_writes_performed": 0,
      "notes": "Rejects review state only. Does not publish."
    },
    {
      "method": "POST",
      "path": "/api/builder/publish-approval-requests/{id}/revoke",
      "purpose": "Revoke requested or approved candidate review state.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": false,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "approval_does_not_publish": true,
      "runtime_writes_performed": 0,
      "notes": "Revokes review state only. Does not publish."
    },
    {
      "method": "GET",
      "path": "/api/builder/definitions/{id}/approved-candidate-preflight",
      "purpose": "Read-only approved candidate preflight check.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "actual_publish": false,
      "runtime_writes_performed": 0,
      "approval_does_not_publish": true,
      "preflight_does_not_publish": true,
      "notes": "Checks approved candidate freshness and eligibility flags. Does not mutate approval state, create audit logs, or publish."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/archive",
      "purpose": "Archive an unpublished Builder definition.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "uninstall_related": false,
      "destructive_runtime_related": false,
      "response_shape": ["definition", "message"],
      "notes": "Control-plane-only status change. Does not delete runtime modules, files, migrations, tables, or preview artifacts."
    },
    {
      "method": "POST",
      "path": "/api/builder/definitions/{id}/restore",
      "purpose": "Restore an archived Builder definition to draft.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "uninstall_related": false,
      "destructive_runtime_related": false,
      "response_shape": ["definition", "message"],
      "notes": "Control-plane-only status change. Does not change runtime modules, files, migrations, or tables."
    },
    {
      "method": "DELETE",
      "path": "/api/builder/definitions/{id}",
      "purpose": "Delete unpublished Builder draft/control-plane records.",
      "status": "implemented",
      "safe_for_ui": true,
      "safe_for_agent": true,
      "requires_admin": true,
      "publish_related": false,
      "uninstall_related": false,
      "destructive_runtime_related": false,
      "response_shape": ["message"],
      "notes": "Deletes Builder definition/version/preview-run records only. Does not delete runtime modules, generated files, database tables, migrations, media, business data, or preview artifact directories."
    }
  ]
}
