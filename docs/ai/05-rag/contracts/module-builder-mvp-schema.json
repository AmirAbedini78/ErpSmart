{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erpsmart.local/schemas/module-builder-mvp-schema.json",
  "title": "ERPSMART Definition-Driven Module Builder Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "module", "resource", "fields", "capabilities", "permissions", "frontend", "verifier"],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 1},
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "namespace", "singularLabel", "pluralLabel", "table", "routeName", "resourceName", "icon"],
      "properties": {
        "name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$"},
        "namespace": {"type": "string", "pattern": "^Modules\\\\[A-Z][A-Za-z0-9]*$"},
        "singularLabel": {"type": "string", "minLength": 1},
        "pluralLabel": {"type": "string", "minLength": 1},
        "table": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "routeName": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
        "resourceName": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
        "icon": {"type": "string", "minLength": 1}
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelClass", "titleField", "orderBy", "hasDetailView", "globalSearchAction"],
      "properties": {
        "modelClass": {"type": "string", "pattern": "^Modules\\\\[A-Z][A-Za-z0-9]*\\\\Models\\\\[A-Z][A-Za-z0-9]*$"},
        "titleField": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "orderBy": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "hasDetailView": {"type": "boolean"},
        "globalSearchAction": {"type": "string", "enum": ["float", "navigate", "none"]}
      }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "label", "rules", "visibility"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "type": {"type": "string", "enum": ["id", "text", "textarea", "boolean", "integer", "decimal", "date", "datetime", "select", "belongsTo"]},
          "label": {"type": "string", "minLength": 1},
          "primary": {"type": "boolean", "default": false},
          "required": {"type": "boolean", "default": false},
          "default": {},
          "rules": {"type": "array", "items": {"type": "string"}},
          "creationRules": {"type": "array", "items": {"type": "string"}},
          "updateRules": {"type": "array", "items": {"type": "string"}},
          "visibility": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "detail", "create", "update"],
            "properties": {
              "index": {"type": "boolean"},
              "detail": {"type": "boolean"},
              "create": {"type": "boolean"},
              "update": {"type": "boolean"},
              "settings": {"type": "boolean", "default": true}
            }
          },
          "table": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "width": {"type": "string"},
              "minWidth": {"type": "string"},
              "primary": {"type": "boolean"},
              "route": {"type": "string"}
            }
          },
          "relation": {"type": "string"}
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "targetModule", "targetModel", "targetResource", "foreignKey"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][A-Za-z0-9]*$"},
          "type": {"type": "string", "enum": ["belongsTo", "hasMany", "hasOne", "belongsToMany", "morphMany", "morphToMany"]},
          "targetModule": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$"},
          "targetModel": {"type": "string", "pattern": "^Modules\\\\[A-Z][A-Za-z0-9]*\\\\Models\\\\[A-Z][A-Za-z0-9]*$"},
          "targetResource": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
          "localKey": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "foreignKey": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "displayField": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "required": {"type": "boolean"},
          "nullable": {"type": "boolean"},
          "onDelete": {"type": "string", "enum": ["cascade", "restrict", "set null", "no action"]},
          "showOnDetail": {"type": "boolean"},
          "showOnIndex": {"type": "boolean"},
          "generateField": {"type": "boolean"},
          "generateMigrationColumn": {"type": "boolean"},
          "generateFrontendPanel": {"type": "boolean"}
        }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultView", "orderBy"],
      "properties": {
        "defaultView": {"type": "object", "additionalProperties": false, "required": ["name", "flag"], "properties": {"name": {"type": "string"}, "flag": {"type": "string"}}},
        "orderBy": {"type": "object", "additionalProperties": false, "required": ["column", "direction"], "properties": {"column": {"type": "string"}, "direction": {"type": "string", "enum": ["asc", "desc"]}}}
      }
    },
    "detailPage": {"type": "object", "additionalProperties": true},
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tableable", "hasDetailView", "customFields", "importable", "exportable", "cloneable", "media", "notes", "activities", "globalSearch"],
      "properties": {
        "tableable": {"type": "boolean"},
        "hasDetailView": {"type": "boolean"},
        "customFields": {"type": "boolean"},
        "uniqueCustomFields": {"type": "boolean"},
        "importable": {"type": "boolean"},
        "exportable": {"type": "boolean"},
        "cloneable": {"type": "boolean"},
        "bulkDelete": {"type": "boolean"},
        "globalSearch": {"type": "boolean"},
        "quickCreate": {"type": "boolean"},
        "softDeletes": {"type": "boolean"},
        "notes": {"type": "boolean"},
        "comments": {"type": "boolean"},
        "activities": {"type": "boolean"},
        "activityComments": {"type": "boolean"},
        "activityAssociations": {"type": "boolean"},
        "media": {"type": "boolean"},
        "mediable": {"type": "boolean"},
        "documents": {"type": "boolean"},
        "calls": {"type": "boolean"},
        "emails": {"type": "boolean"},
        "emailSending": {"type": "boolean"},
        "tasks": {"type": "boolean"},
        "workflow": {"type": "boolean"},
        "approvals": {"type": "boolean"},
        "notifications": {"type": "boolean"},
        "timeline": {"type": "boolean"},
        "formLayout": {"type": "boolean"},
        "stepperForm": {"type": "boolean"},
        "sections": {"type": "boolean"},
        "conditionalVisibility": {"type": "boolean"}
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view", "create", "edit", "delete"],
      "properties": {
        "view": {"type": "array", "items": {"type": "string"}},
        "create": {"type": "string"},
        "edit": {"type": "array", "items": {"type": "string"}},
        "delete": {"type": "array", "items": {"type": "string"}},
        "bulkDelete": {"type": "string"},
        "import": {"type": "string"},
        "export": {"type": "string"}
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routes", "views", "floatingModal"],
      "properties": {
        "routes": {"type": "boolean"},
        "views": {"type": "array", "items": {"type": "string", "enum": ["index", "create", "edit", "detail"]}},
        "floatingModal": {"type": "boolean"},
        "localTabComponents": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generate", "path", "checks"],
      "properties": {
        "generate": {"type": "boolean"},
        "path": {"type": "string"},
        "checks": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
